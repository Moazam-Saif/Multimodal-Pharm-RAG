# Copy this file to .env and fill in real values.
# .env is git-ignored - never commit real secrets.

# Data file locations (Phase 1) - only needed if running somewhere other
# than the default local project layout (e.g. Colab with Drive-mounted
# data). Leave unset locally - pillrag.data falls back to data/raw/...
EPILLID_ZIP_PATH=
PILLBOX_METADATA_CSV_PATH=

# Google Cloud / Vertex AI (Phase 4 - imprint extraction)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Activeloop Deep Lake (Phase 3 - vector store)
ACTIVELOOP_TOKEN=
DEEPLAKE_IMAGE_STORE_PATH=
DEEPLAKE_TEXT_STORE_PATH=
